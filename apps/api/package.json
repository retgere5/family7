{
  "name": "@family7/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@family7/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "fastify": "^5.10.0",
    "fastify-plugin": "^6.0.0",
    "google-auth-library": "^10.9.0",
    "jose": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "prisma": "^7.8.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}
