generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String
  avatarUrl       String?
  statusEmoji     String?
  sharingPaused   Boolean           @default(false)
  provider        String
  providerId      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  memberships     CircleMember[]
  devices         Device[]
  refreshTokens   RefreshToken[]
  latestLocation  LocationLatest?
  locationHistory LocationHistory[]

  @@unique([provider, providerId])
}

model LocationLatest {
  userId     String   @id
  lat        Float
  lng        Float
  speed      Float?
  heading    Float?
  accuracy   Float?
  battery    Int?
  placeId    String?
  recordedAt DateTime
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  place      Place?   @relation(fields: [placeId], references: [id], onDelete: SetNull)
}

model LocationHistory {
  id         String   @id @default(cuid())
  userId     String
  lat        Float
  lng        Float
  speed      Float?
  heading    Float?
  accuracy   Float?
  battery    Int?
  recordedAt DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([recordedAt])
}

model Circle {
  id         String         @id @default(cuid())
  name       String
  inviteCode String         @unique
  createdAt  DateTime       @default(now())
  members    CircleMember[]
  places     Place[]
}

model Place {
  id        String           @id @default(cuid())
  circleId  String
  name      String
  icon      String
  lat       Float
  lng       Float
  radiusM   Int
  notify    Boolean          @default(true)
  createdAt DateTime         @default(now())
  circle    Circle           @relation(fields: [circleId], references: [id], onDelete: Cascade)
  visitors  LocationLatest[]

  @@index([circleId])
}

enum CircleRole {
  OWNER
  MEMBER
}

model CircleMember {
  circleId String
  userId   String
  role     CircleRole @default(MEMBER)
  joinedAt DateTime   @default(now())
  circle   Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([circleId, userId])
}

model Device {
  id        String   @id @default(cuid())
  userId    String
  pushToken String   @unique
  platform  String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
